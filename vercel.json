{
  "routes": [
    { "src": "/api/(.*)", "dest": "/src/index.ts" },
    { "src": "/assets/(.*)", "dest": "/src/index.ts" },
    { "src": "/tailwind.css", "dest": "/src/index.ts" },
    { "src": "/frontend.js", "dest": "/src/index.ts" },
    { "src": "/dashboard", "dest": "/src/index.ts" },
    { "src": "/about", "dest": "/src/index.ts" },
    { "src": "/contact", "dest": "/src/index.ts" },
    { "src": "/(.*)", "dest": "/src/index.ts" }
  ]
}
